<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.StackPane?>


<StackPane xmlns:fx="http://javafx.com/fxml/1"
	xmlns="http://javafx.com/javafx/21"
	fx:controller="JavaApplication2.LoginController"
	alignment="CENTER"
	stylesheets="@estilo.css"
	styleClass="background"
>
	
<VBox alignment="CENTER">
	<VBox styleClass="card-branco" alignment ="CENTER" spacing="20">
		<Label text="Login" styleClass="titulo"/>
		<TextField fx:id="email" promptText="Email" styleClass="campo"/>
		<PasswordField fx:id="senha" promptText="Senha" styleClass="campo"/>
	
		<HBox spacing="40" alignment="CENTER_LEFT" styleClass="opcoes">
			<CheckBox text="Lembre-me" styleClass="checkbox"/>
			<Hyperlink text="Esqueceu a senha?" styleClass="link"/>
		</HBox>
		
	<Button text="Entrar" styleClass="botao-login" onAction="#Login"/>

	</VBox>
</VBox>

</StackPane>
